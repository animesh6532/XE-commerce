# Database Configurations
# MySQL Connection
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=xecomerce

# SQLAlchemy connection string (MySQL / SQLite fallback)
DATABASE_URL=mysql+pymysql://root:your_mysql_password@localhost:3306/xecomerce
# Fallback SQLite for quick local dev: sqlite:///./ecommerce.db

# Authentication Configurations
# Secret key used for JWT token signing
JWT_SECRET=your_jwt_secret_key_change_me_in_production

# Notification Configurations (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_email_app_password

# Machine Learning Configurations
# Path to saved model directory
MODEL_PATH=ml_models/saved_models
